{
  "name": "server",
  "version": "1.0.0",
  "description": "SiteForge construction project and resource management API",
  "main": "server.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "node -e \"console.log('Server uses native ES modules; no build step is required.')\"",
    "test": "node --test tests/auth.test.js tests/phase2.test.js",
    "test:jest": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand tests/auth.jest.test.js",
    "migrate": "node src/migrations/runMigrations.js"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "jest": "^29.6.1",
    "@types/jest": "^29.5.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.[jt]s?(x)", "**/tests/**/*.spec.[jt]s?(x)"]
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  }
}
