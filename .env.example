# Docker Compose development values. Replace the secrets before deployment.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=siteforge
JWT_SECRET=replace-with-a-long-random-jwt-secret
REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret
# Comma-separated origins are supported, for example https://app.example.com,https://www.example.com
CLIENT_ORIGIN=http://localhost:5173
# Local Docker uses HTTP; production deployments should use true and none over HTTPS.
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
# Leave empty when Nginx proxies /api. Set https://api.example.com for separate deployments.
VITE_API_BASE_URL=
VITE_DEV_API_URL=http://localhost:4000
